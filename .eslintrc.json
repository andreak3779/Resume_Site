{
    "env": {
        "browser": true,
        "commonjs": true,
        "es6": true,
        "node": true
    },
    "parserOptions": {
        "ecmaFeatures": {
            "jsx": true
        },
        "sourceType": "module"
    },
    "rules": {
        "no&#45;const&#45;assign": "warn",
        "no&#45;this&#45;before&#45;super": "warn",
        "no&#45;undef": "warn",
        "no&#45;unreachable": "warn",
        "no&#45;unused&#45;vars": "warn",
        "constructor&#45;super": "warn",
        "valid&#45;typeof": "warn"
    }
}